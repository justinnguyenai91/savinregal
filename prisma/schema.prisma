// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== USER & AUTH =====
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  password      String
  role          String    @default("customer") // customer | admin
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  reviews       Review[]
  addresses     Address[]
  wishlist      Wishlist[]
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  fullName   String
  phone      String
  province   String
  district   String
  ward       String
  address    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]
}

// ===== PRODUCT =====
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  products    Product[]
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String
  description      String
  price            Float
  originalPrice    Float?
  images           String   // JSON array stored as string
  categoryId       String
  badges           String   @default("[]") // JSON array: bestseller, new, sale, limited
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  inStock          Boolean  @default(true)
  stockQuantity    Int      @default(0)
  benefits         String   @default("[]") // JSON array
  ingredients      String   @default("[]") // JSON array of {name, amount, description}
  usage            String?
  warnings         String   @default("[]") // JSON array
  certifications   String   @default("[]") // JSON array
  origin           String?
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category         Category       @relation(fields: [categoryId], references: [id])
  variants         ProductVariant[]
  reviews          Review[]
  orderItems       OrderItem[]
  wishlist         Wishlist[]
  supplierProducts SupplierProduct[]
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  name          String
  price         Float
  originalPrice Float?
  inStock       Boolean  @default(true)
  stockQuantity Int      @default(0)
  sortOrder     Int      @default(0)

  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
}

// ===== ORDER =====
model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  userId          String?
  addressId       String?
  
  // Guest checkout info
  guestName       String?
  guestPhone      String?
  guestEmail      String?
  guestAddress    String?

  status          String   @default("pending") // pending, confirmed, processing, shipping, delivered, cancelled
  paymentMethod   String   // vnpay, momo, cod, transfer
  paymentStatus   String   @default("pending") // pending, paid, failed, refunded
  paymentRef      String?  // transaction ID from payment gateway

  subtotal        Float
  shippingFee     Float    @default(0)
  discount        Float    @default(0)
  total           Float

  trackingNumber  String?
  shippingProvider String?
  note            String?

  // Dropship fields
  supplierId      String?
  supplierOrderId String?
  supplierStatus  String?
  profitMargin    Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?     @relation(fields: [userId], references: [id])
  address         Address?  @relation(fields: [addressId], references: [id])
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  items           OrderItem[]
  payment         Payment?
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  variantId  String?
  quantity   Int
  unitPrice  Float
  totalPrice Float

  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
}

model Payment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  method          String   // vnpay, momo, cod, transfer
  amount          Float
  status          String   @default("pending") // pending, success, failed, refunded
  transactionId   String?
  gatewayResponse String?  // JSON response from gateway
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  order           Order    @relation(fields: [orderId], references: [id])
}

// ===== REVIEW =====
model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  content   String
  images    String   @default("[]") // JSON array
  verified  Boolean  @default(false)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

// ===== WISHLIST =====
model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ===== COUPON =====
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  discountType   String    // percentage | fixed
  discountValue  Float
  minOrderAmount Float?
  maxDiscount    Float?
  usageLimit     Int?
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
}

// ===== DROPSHIP / SUPPLIER =====
model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  products    SupplierProduct[]
  orders      Order[]
}

model SupplierProduct {
  id            String  @id @default(cuid())
  supplierId    String
  productId     String
  supplierSKU   String?
  costPrice     Float   // Giá gốc từ supplier
  isActive      Boolean @default(true)

  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
}

// ===== BLOG =====
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  image       String?
  author      String
  category    String?
  readTime    Int      @default(5)
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== SETTINGS =====
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
